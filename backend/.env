PRODUCTION CHANGES (when deploying to Railway)
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=production
API_BASE_URL=https://your-app.up.railway.app
FRONTEND_URL=https://your-app.vercel.app
DB_HOST=<railway gives you this>
DB_PASSWORD=<railway gives you this>
REDIS_HOST=<upstash or railway redis host>
REDIS_PASSWORD=<upstash or railway redis password>
